# Copy to server/.env and fill in. On Hostinger, set these in the
# Node.js app "Environment variables" panel instead of a file.

# MySQL / MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=tijus_timetable

# API
PORT=4000
# Use a long random string in production, e.g. `openssl rand -hex 32`
JWT_SECRET=change-this-to-a-long-random-secret
